{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "phreaknic speakers.json",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "topic", "initials", "bio"],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "topic": {
        "type": "string",
        "minLength": 1
      },
      "initials": {
        "type": "string",
        "pattern": "^[A-Z]{2}$"
      },
      "bio": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1
      },
      "twitter": {
        "type": "string",
        "format": "uri"
      },
      "github": {
        "type": "string",
        "format": "uri"
      },
      "website": {
        "type": "string",
        "format": "uri"
      }
    },
    "additionalProperties": false
  }
}
